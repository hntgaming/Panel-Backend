# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Supported engines: postgresql, mysql
DB_ENGINE=postgresql
DB_NAME=publisher_dashboard
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010
CORS_ALLOW_ALL_ORIGINS=False

# GAM (Google Ad Manager) Configuration
# Each partner admin connects their own GAM account via the dashboard.
# The service account below is shared — partners add it as admin in their GAM.
GAM_PROJECT_ID=your-gcp-project-id
GAM_APPLICATION_NAME=Your App Name
GAM_API_VERSION=v202508
GAM_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GAM_PRIVATE_KEY_FILE=key.json

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@domain.com

# Optional: Slack Webhook for Alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
